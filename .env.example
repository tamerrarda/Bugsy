# Root .env — used ONLY by things that run on your machine / in CI:
# scripts/seed.ts, scripts/store-shots.mjs, supabase/tests/*.
# Fill from `npx supabase status`.
#
# The service-role key bypasses RLS. It must never appear anywhere under
# extension/, and must never be bundled. The extension gets the anon key only,
# via extension/.env.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub OAuth App, read by supabase/config.toml via env(). Local dev only —
# production uses a separate app whose secret lives in the Supabase dashboard.
GITHUB_CLIENT_ID=
GITHUB_SECRET=
