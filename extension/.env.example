# The extension gets the ANON key and nothing else.
#
# The service-role key must NEVER appear in this file or anywhere under
# extension/ — it bypasses RLS, and everything here is shipped to users
# (spec §10). Seeding uses the root .env instead.
#
# Fill from `npx supabase status`.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
