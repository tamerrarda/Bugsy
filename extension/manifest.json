{
  "manifest_version": 3,
  "name": "Bugsy — Spot the Bug",
  "description": "Wordle for debugging. Three snippets a day, one bug each. Find it before the timer does.",
  "version": "0.1.0",
  "key": "",
  "action": {
    "default_popup": "index.html",
    "default_title": "Bugsy",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "alarms", "notifications", "identity"],
  "host_permissions": [
    "http://127.0.0.1:54321/*",
    "https://*.supabase.co/*"
  ],
  "minimum_chrome_version": "116"
}
