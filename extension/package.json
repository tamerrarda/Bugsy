{
  "name": "bugsy-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "content": "node ../scripts/seed.ts --emit",
    "predev": "npm run content",
    "dev": "vite",
    "prebuild": "npm run content",
    "build": "tsc --noEmit && vite build",
    "pretypecheck": "npm run content",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run content",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
